@import "tailwindcss";

@layer base {
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
  body {
    background-color: var(--sys-background);
    color: var(--sys-on-background);
    font-family: var(--font-inter), sans-serif;
  }
}

:root {
  --sys-background: #f7f9fb;
  --sys-error: #ba1a1a;
  --sys-error-container: #ffdad6;
  --sys-inverse-on-surface: #eff1f3;
  --sys-inverse-primary: #bec6e0;
  --sys-inverse-surface: #2d3133;
  --sys-on-background: #191c1e;
  --sys-on-error: #ffffff;
  --sys-on-error-container: #93000a;
  --sys-on-primary: #ffffff;
  --sys-on-primary-container: #7c839b;
  --sys-on-primary-fixed: #131b2e;
  --sys-on-primary-fixed-variant: #3f465c;
  --sys-on-secondary: #ffffff;
  --sys-on-secondary-container: #57657b;
  --sys-on-secondary-fixed: #0d1c2f;
  --sys-on-secondary-fixed-variant: #3a485c;
  --sys-on-surface: #191c1e;
  --sys-on-surface-variant: #45464d;
  --sys-on-tertiary: #ffffff;
  --sys-on-tertiary-container: #188ace;
  --sys-on-tertiary-fixed: #001d31;
  --sys-on-tertiary-fixed-variant: #004b73;
  --sys-outline: #76777d;
  --sys-outline-variant: #c6c6cd;
  --sys-primary: #000000;
  --sys-primary-container: #131b2e;
  --sys-primary-fixed: #dae2fd;
  --sys-primary-fixed-dim: #bec6e0;
  --sys-secondary: #515f74;
  --sys-secondary-container: #d5e3fd;
  --sys-secondary-fixed: #d5e3fd;
  --sys-secondary-fixed-dim: #b9c7e0;
  --sys-surface: #f7f9fb;
  --sys-surface-bright: #f7f9fb;
  --sys-surface-container: #eceef0;
  --sys-surface-container-high: #e6e8ea;
  --sys-surface-container-highest: #e0e3e5;
  --sys-surface-container-low: #f2f4f6;
  --sys-surface-container-lowest: #ffffff;
  --sys-surface-dim: #d8dadc;
  --sys-surface-tint: #565e74;
  --sys-surface-variant: #e0e3e5;
  --sys-tertiary: #000000;
  --sys-tertiary-container: #001d31;
  --sys-tertiary-fixed: #cce5ff;
  --sys-tertiary-fixed-dim: #93ccff;
}


@theme {
  --font-inter: 'Inter', sans-serif;
  --font-jetbrains-mono: 'JetBrains Mono', monospace;

  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);
  --color-: var(--sys-);

  --text-body-lg: 16px;
  --text-body-lg--line-height: 24px;
  --font-weight-body-lg: 400;
  --text-body-md: 14px;
  --text-body-md--line-height: 20px;
  --font-weight-body-md: 400;
  --text-code: 13px;
  --text-code--line-height: 20px;
  --font-weight-code: 400;
  --text-headline-lg: 32px;
  --text-headline-lg--line-height: 40px;
  --font-weight-headline-lg: 600;
  --tracking-headline-lg: -0.02em;
  --text-headline-lg-mobile: 24px;
  --text-headline-lg-mobile--line-height: 32px;
  --font-weight-headline-lg-mobile: 600;
  --tracking-headline-lg-mobile: -0.01em;
  --text-headline-md: 20px;
  --text-headline-md--line-height: 28px;
  --font-weight-headline-md: 600;
  --text-label-md: 12px;
  --text-label-md--line-height: 16px;
  --font-weight-label-md: 500;
  --tracking-label-md: 0.05em;

  --spacing-base: 4px;
  --spacing-container-max: 1440px;
  --spacing-gutter: 24px;
  --spacing-margin-desktop: 40px;
  --spacing-margin-mobile: 16px;

  --radius-sm: 0.125rem;
  --radius: 0.25rem;
  --radius-md: 0.375rem;
  --radius-lg: 0.5rem;
  --radius-xl: 0.75rem;
  --radius-full: 9999px;
}

@media print {
  body, html, #root, .overflow-hidden, .overflow-y-auto {
    height: auto !important;
    overflow: visible !important;
    position: static !important;
  }
  /* Components will use print:hidden and print:block classes to manage visibility natively */
  #print-invoice, #print-statement-of-account {
    zoom: 0.9;
    transform: scale(0.9);
    transform-origin: top center;
  }
}

/* Dark Mode Palette */
.dark {
  --sys-background: #0f1115;
  --sys-on-background: #e2e8f0;
  
  --sys-primary: #ffffff;
  --sys-on-primary: #000000;
  
  --sys-secondary: #94a3b8;
  --sys-on-secondary: #ffffff;
  
  --sys-surface: #0f1115;
  --sys-on-surface: #e2e8f0;
  
  --sys-surface-container-lowest: #13161c;
  --sys-surface-container-low: #1a1d24;
  --sys-surface-container: #1f232b;
  --sys-surface-container-high: #272c36;
  --sys-surface-container-highest: #333945;
  
  --sys-outline: #64748b;
  --sys-outline-variant: #334155;
  
  --sys-error: #f87171;
  --sys-error-container: #7f1d1d;
  --sys-on-error-container: #fecaca;
  
  --sys-primary-container: #1e293b;
  --sys-on-primary-container: #cbd5e1;
  
  --sys-secondary-container: #0f172a;
  --sys-on-secondary-container: #94a3b8;
  
  --sys-tertiary-container: #082f49;
  --sys-on-tertiary-container: #7dd3fc;
}
